# Supabase — get these from your project's Settings > API page
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Books API — get a key at https://console.cloud.google.com
# Enable the "Books API" and create an API key
GOOGLE_BOOKS_API_KEY=your-google-books-api-key-here

# Optional: Open Library doesn't require a key but you can set a base URL override
OPEN_LIBRARY_BASE_URL=https://openlibrary.org
